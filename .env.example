# ─────────────────────────────────────────────────────────────────────────────
# Single source of truth for the app's ports (and the browser → API URL).
#
# Copy this file to `.env` and adjust for your machine:
#     cp .env.example .env
#
# Everything reads from `.env`: Docker Compose (host port mapping + the frontend
# build), the local dev servers (`make dev-backend` / `make dev-frontend`), and
# the backend itself (sim_stochastic_pv/config.py). When `.env` is absent, the
# launchers and the backend fall back to THIS file and log a warning.
# ─────────────────────────────────────────────────────────────────────────────

# Host port for the backend API. The container/uvicorn listen internally on
# 8000; this is the port published on the host and the one the browser calls.
BACKEND_PORT=8001

# Host port for the frontend. In Docker the nginx container listens on 80 and is
# published here; the Vite dev server binds this port directly.
FRONTEND_PORT=5174

# URL the browser uses to reach the backend. Baked into the frontend build and
# used by the Vite dev server. Must match BACKEND_PORT above.
VITE_API_BASE=http://localhost:8001/api
